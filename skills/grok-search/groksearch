#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${GROKSEARCH_VENV_DIR:-$ROOT_DIR/.venv}"
REQ_FILE="$ROOT_DIR/requirements.txt"

find_python() {
  if [[ -n "${AGENTS_SKILLS_PYTHON:-}" && -x "${AGENTS_SKILLS_PYTHON}" ]]; then
    echo "${AGENTS_SKILLS_PYTHON}"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    command -v python
    return 0
  fi
  return 1
}

python_spec() {
  if [[ -n "${GROKSEARCH_PYTHON:-}" ]]; then
    echo "${GROKSEARCH_PYTHON}"
    return 0
  fi
  if [[ -n "${AGENTS_SKILLS_PYTHON:-}" ]]; then
    echo "${AGENTS_SKILLS_PYTHON}"
    return 0
  fi
  return 1
}

create_venv() {
  if command -v uv >/dev/null 2>&1; then
    local spec=""
    spec="$(python_spec || true)"
    if [[ -n "$spec" ]]; then
      uv venv --python "$spec" "$VENV_DIR"
    else
      uv venv "$VENV_DIR"
    fi
    return 0
  fi

  local bootstrap_py=""
  bootstrap_py="$(find_python || true)"
  if [[ -z "$bootstrap_py" ]]; then
    echo "Error: 未找到可用的 uv 或 python/python3，无法创建虚拟环境" >&2
    exit 1
  fi
  "$bootstrap_py" -m venv "$VENV_DIR"
}

if [[ -e "$VENV_DIR" && ! -d "$VENV_DIR" ]]; then
  echo "Error: $VENV_DIR 已存在但不是目录，请设置 GROKSEARCH_VENV_DIR 或删除该路径" >&2
  exit 1
fi
if [[ -d "$VENV_DIR" && ! -f "$VENV_DIR/pyvenv.cfg" && ! -x "$VENV_DIR/bin/python" ]]; then
  echo "Error: $VENV_DIR 已存在但不是虚拟环境，请设置 GROKSEARCH_VENV_DIR 或清理该目录" >&2
  exit 1
fi
if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  create_venv
fi

PY_BIN="$VENV_DIR/bin/python"

if ! "$PY_BIN" -c "import httpx, tenacity" >/dev/null 2>&1; then
  if command -v uv >/dev/null 2>&1 && [[ -f "$REQ_FILE" ]]; then
    uv pip install --python "$PY_BIN" -r "$REQ_FILE"
  elif [[ -f "$REQ_FILE" ]]; then
    "$PY_BIN" -m pip install -r "$REQ_FILE"
  else
    "$PY_BIN" -m pip install httpx tenacity
  fi
fi

exec "$PY_BIN" "$ROOT_DIR/scripts/groksearch_cli.py" "$@"
